# pyenv
#   For a library or binary, you wish to ignore these files.
#   For a specific project, you may wish to check these files in.
# .python-version

# pipenv
#   According to pypa/pipenv#1181, it is recommended to include Pipfile.lock in version control.
#   However, in cases where the author of a library or binary has a specific reason to not
#   want to lock dependencies, they may opt to include it in .gitignore.
# Pipfile.lock

# poetry
#   Similar to Pipfile.lock, it is generally recommended to include poetry.lock in version control.
#   poetry.lock

# pdm
#   Similar to Pipfile.lock, it is generally recommended to include pdm.lock in version control.
# pdm.lock
#   pdm envs
.pdm-python

# PEP 582; used by e.g. github.com/pdm-project/pdm
__pypackages__/

